# Hacker News - NO KEY NEEDED (leave blank)
# Bluesky - NO KEY NEEDED for public read (leave blank)

# Stack Exchange - free app key from stackapps.com (raises quota from 300 to 10,000/day)
STACKEXCHANGE_API_KEY=your_stack_exchange_key_here

# The Guardian - free key from open-platform.theguardian.com
GUARDIAN_API_KEY=your_guardian_key_here

# Output directory for saved search history
OUTPUT_DIR=output

# Optional: set to "true" to enable debug logging
DEBUG=false
